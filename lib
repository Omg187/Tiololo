local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local Players = game:GetService("Players")

local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

local NovaLib = {}
NovaLib.__index = NovaLib

-- ======= TEMA =======
local Theme = {
    Background     = Color3.fromRGB(10, 10, 12),
    Panel          = Color3.fromRGB(16, 16, 18),
    PanelAlt       = Color3.fromRGB(22, 22, 25),
    Stroke         = Color3.fromRGB(35, 35, 40),
    Accent         = Color3.fromRGB(190, 30, 40),   -- vermelho estilo "Spectra"
    AccentDim      = Color3.fromRGB(90, 20, 25),
    Text           = Color3.fromRGB(235, 235, 240),
    SubText        = Color3.fromRGB(150, 150, 158),
    Font           = Enum.Font.GothamBold,
    FontRegular    = Enum.Font.Gotham,
}

-- ======= HELPERS =======
local function create(class, props, children)
    local inst = Instance.new(class)
    for k, v in pairs(props or {}) do
        inst[k] = v
    end
    for _, child in ipairs(children or {}) do
        child.Parent = inst
    end
    return inst
end

local function tween(obj, props, time, style, dir)
    local t = TweenService:Create(obj, TweenInfo.new(time or 0.2, style or Enum.EasingStyle.Quad, dir or Enum.EasingDirection.Out), props)
    t:Play()
    return t
end

local function corner(radius)
    return create("UICorner", {CornerRadius = UDim.new(0, radius or 8)})
end

local function stroke(color, thickness)
    return create("UIStroke", {Color = color or Theme.Stroke, Thickness = thickness or 1})
end

local function padding(all)
    return create("UIPadding", {
        PaddingTop = UDim.new(0, all or 8),
        PaddingBottom = UDim.new(0, all or 8),
        PaddingLeft = UDim.new(0, all or 8),
        PaddingRight = UDim.new(0, all or 8),
    })
end

-- ======= JANELA PRINCIPAL =======
function NovaLib.new(config)
    config = config or {}
    local title       = config.Title or "Nova Hub"
    local subtitle     = config.Subtitle or "by you | v1.0"
    local size         = config.Size or UDim2.new(0, 480, 0, 560)

    local self = setmetatable({}, NovaLib)

    -- ScreenGui
    self.ScreenGui = create("ScreenGui", {
        Name = "NovaLib",
        Parent = PlayerGui,
        ResetOnSpawn = false,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
    })

    -- Janela principal
    self.Main = create("Frame", {
        Name = "Main",
        Parent = self.ScreenGui,
        Size = size,
        Position = UDim2.new(0.5, -size.X.Offset/2, 0.5, -size.Y.Offset/2),
        BackgroundColor3 = Theme.Background,
        BorderSizePixel = 0,
        ClipsDescendants = true,
    }, {corner(12), stroke(Theme.Accent, 1)})

    -- Barra de tÃ­tulo
    local topBar = create("Frame", {
        Name = "TopBar",
        Parent = self.Main,
        Size = UDim2.new(1, 0, 0, 54),
        BackgroundColor3 = Theme.Panel,
        BorderSizePixel = 0,
    }, {corner(12)})

    -- corrige o corner sÃ³ em cima
    create("Frame", {
        Parent = topBar,
        Size = UDim2.new(1, 0, 0, 12),
        Position = UDim2.new(0, 0, 1, -12),
        BackgroundColor3 = Theme.Panel,
        BorderSizePixel = 0,
        ZIndex = 0,
    })

    create("TextLabel", {
        Parent = topBar,
        Text = title,
        Font = Theme.Font,
        TextSize = 20,
        TextColor3 = Theme.Accent,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 16, 0, 6),
        Size = UDim2.new(1, -32, 0, 26),
        TextXAlignment = Enum.TextXAlignment.Left,
    })

    create("TextLabel", {
        Parent = topBar,
        Text = subtitle,
        Font = Theme.FontRegular,
        TextSize = 12,
        TextColor3 = Theme.SubText,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 16, 0, 30),
        Size = UDim2.new(1, -32, 0, 16),
        TextXAlignment = Enum.TextXAlignment.Left,
    })

    -- BotÃ£o de fechar
    local closeBtn = create("TextButton", {
        Parent = topBar,
        Text = "Ã—",
        Font = Theme.Font,
        TextSize = 22,
        TextColor3 = Theme.SubText,
        BackgroundTransparency = 1,
        Size = UDim2.new(0, 36, 0, 36),
        Position = UDim2.new(1, -44, 0, 9),
    })
    closeBtn.MouseEnter:Connect(function() tween(closeBtn, {TextColor3 = Theme.Accent}, 0.15) end)
    closeBtn.MouseLeave:Connect(function() tween(closeBtn, {TextColor3 = Theme.SubText}, 0.15) end)
    closeBtn.MouseButton1Click:Connect(function()
        self:Toggle(false)
    end)

    -- Ãrea de conteÃºdo (scroll, sem abas â€” tudo empilhado)
    local scroll = create("ScrollingFrame", {
        Name = "Content",
        Parent = self.Main,
        Position = UDim2.new(0, 0, 0, 54),
        Size = UDim2.new(1, 0, 1, -54),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ScrollBarThickness = 3,
        ScrollBarImageColor3 = Theme.Accent,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
    }, {
        padding(14),
        create("UIListLayout", {
            Padding = UDim.new(0, 10),
            SortOrder = Enum.SortOrder.LayoutOrder,
        }),
    })
    self.Content = scroll

    -- Arrastar a janela pela topbar
    do
        local dragging, dragStart, startPos
        topBar.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = true
                dragStart = input.Position
                startPos = self.Main.Position
                input.Changed:Connect(function()
                    if input.UserInputState == Enum.UserInputState.End then
                        dragging = false
                    end
                end)
            end
        end)
        topBar.InputChanged:Connect(function(input)
            if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                local delta = input.Position - dragStart
                self.Main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
            end
        end)
    end

    -- Tecla para abrir/fechar (padrÃ£o: RightShift)
    self._visible = true
    self._toggleKey = config.ToggleKey or Enum.KeyCode.RightShift
    UserInputService.InputBegan:Connect(function(input, gpe)
        if gpe then return end
        if input.KeyCode == self._toggleKey then
            self:Toggle(not self._visible)
        end
    end)

    return self
end

function NovaLib:Toggle(state)
    self._visible = state
    self.Main.Visible = state
end

-- ======= SEÃ‡ÃƒO (tÃ­tulo tipo "Janela", "Lua", "Caveira" na imagem) =======
function NovaLib:AddSection(name)
    local label = create("TextLabel", {
        Parent = self.Content,
        Text = name,
        Font = Theme.Font,
        TextSize = 16,
        TextColor3 = Theme.Accent,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 22),
        TextXAlignment = Enum.TextXAlignment.Left,
        LayoutOrder = #self.Content:GetChildren(),
    })
    return label
end

-- ======= CARD base para elementos =======
local function makeCard(parent, height)
    return create("Frame", {
        Parent = parent,
        Size = UDim2.new(1, 0, 0, height or 50),
        BackgroundColor3 = Theme.Panel,
        BorderSizePixel = 0,
        LayoutOrder = #parent:GetChildren(),
    }, {corner(8), padding(10)})
end

-- ======= TOGGLE =======
function NovaLib:AddToggle(text, desc, default, callback)
    local card = makeCard(self.Content, desc and 50 or 40)

    create("TextLabel", {
        Parent = card,
        Text = text,
        Font = Theme.Font,
        TextSize = 14,
        TextColor3 = Theme.Text,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -60, 0, 18),
        Position = UDim2.new(0, 0, 0, 0),
        TextXAlignment = Enum.TextXAlignment.Left,
    })

    if desc then
        create("TextLabel", {
            Parent = card,
            Text = desc,
            Font = Theme.FontRegular,
            TextSize = 11,
            TextColor3 = Theme.SubText,
            BackgroundTransparency = 1,
            Size = UDim2.new(1, -60, 0, 14),
            Position = UDim2.new(0, 0, 0, 18),
            TextXAlignment = Enum.TextXAlignment.Left,
        })
    end

    local switch = create("Frame", {
        Parent = card,
        Size = UDim2.new(0, 40, 0, 20),
        Position = UDim2.new(1, -40, 0.5, -10),
        BackgroundColor3 = default and Theme.Accent or Theme.PanelAlt,
        BorderSizePixel = 0,
    }, {corner(10), stroke(Theme.Stroke, 1)})

    local knob = create("Frame", {
        Parent = switch,
        Size = UDim2.new(0, 16, 0, 16),
        Position = default and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8),
        BackgroundColor3 = Theme.Text,
        BorderSizePixel = 0,
    }, {corner(8)})

    local state = default or false
    local click = create("TextButton", {
        Parent = switch,
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = "",
    })

    click.MouseButton1Click:Connect(function()
        state = not state
        tween(switch, {BackgroundColor3 = state and Theme.Accent or Theme.PanelAlt}, 0.15)
        tween(knob, {Position = state and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8)}, 0.15)
        if callback then callback(state) end
    end)

    return {
        Set = function(_, v)
            state = v
            switch.BackgroundColor3 = state and Theme.Accent or Theme.PanelAlt
            knob.Position = state and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8)
        end,
        Get = function() return state end,
    }
end

-- ======= SLIDER =======
function NovaLib:AddSlider(text, desc, min, max, default, callback)
    local card = makeCard(self.Content, 54)

    create("TextLabel", {
        Parent = card,
        Text = text,
        Font = Theme.Font,
        TextSize = 14,
        TextColor3 = Theme.Text,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -50, 0, 16),
        TextXAlignment = Enum.TextXAlignment.Left,
    })

    if desc then
        create("TextLabel", {
            Parent = card,
            Text = desc,
            Font = Theme.FontRegular,
            TextSize = 11,
            TextColor3 = Theme.SubText,
            BackgroundTransparency = 1,
            Position = UDim2.new(0, 0, 0, 16),
            Size = UDim2.new(1, -50, 0, 14),
            TextXAlignment = Enum.TextXAlignment.Left,
        })
    end

    local valueLabel = create("TextLabel", {
        Parent = card,
        Text = tostring(default),
        Font = Theme.Font,
        TextSize = 14,
        TextColor3 = Theme.Accent,
        BackgroundTransparency = 1,
        Size = UDim2.new(0, 40, 0, 16),
        Position = UDim2.new(1, -40, 0, 0),
        TextXAlignment = Enum.TextXAlignment.Right,
    })

    local track = create("Frame", {
        Parent = card,
        Size = UDim2.new(1, 0, 0, 6),
        Position = UDim2.new(0, 0, 1, -10),
        BackgroundColor3 = Theme.PanelAlt,
        BorderSizePixel = 0,
    }, {corner(3)})

    local ratio = (default - min) / (max - min)
    local fill = create("Frame", {
        Parent = track,
        Size = UDim2.new(ratio, 0, 1, 0),
        BackgroundColor3 = Theme.Accent,
        BorderSizePixel = 0,
    }, {corner(3)})

    local dragging = false
    local function update(inputPos)
        local relX = math.clamp((inputPos.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
        local value = math.floor(min + (max - min) * relX)
        fill.Size = UDim2.new(relX, 0, 1, 0)
        valueLabel.Text = tostring(value)
        if callback then callback(value) end
        return value
    end

    track.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            update(input.Position)
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            update(input.Position)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)

    return {
        Set = function(_, v)
            local relX = math.clamp((v - min) / (max - min), 0, 1)
            fill.Size = UDim2.new(relX, 0, 1, 0)
            valueLabel.Text = tostring(v)
        end
    }
end

-- ======= BOTÃƒO =======
function NovaLib:AddButton(text, callback)
    local card = makeCard(self.Content, 40)
    card.BackgroundColor3 = Theme.PanelAlt

    local btnLabel = create("TextLabel", {
        Parent = card,
        Text = text,
        Font = Theme.Font,
        TextSize = 14,
        TextColor3 = Theme.Text,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 1, 0),
        TextXAlignment = Enum.TextXAlignment.Left,
    })

    local click = create("TextButton", {
        Parent = card,
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = "",
    })

    click.MouseEnter:Connect(function() tween(btnLabel, {TextColor3 = Theme.Accent}, 0.15) end)
    click.MouseLeave:Connect(function() tween(btnLabel, {TextColor3 = Theme.Text}, 0.15) end)
    click.MouseButton1Click:Connect(function()
        tween(card, {BackgroundColor3 = Theme.Accent}, 0.08)
        task.delay(0.1, function() tween(card, {BackgroundColor3 = Theme.PanelAlt}, 0.2) end)
        if callback then callback() end
    end)

    return card
end

-- ======= DROPDOWN =======
function NovaLib:AddDropdown(text, options, default, callback)
    local card = makeCard(self.Content, 40)
    local expanded = false
    local selected = default or options[1]

    create("TextLabel", {
        Parent = card,
        Text = text,
        Font = Theme.Font,
        TextSize = 14,
        TextColor3 = Theme.Text,
        BackgroundTransparency = 1,
        Size = UDim2.new(0.5, 0, 1, 0),
        TextXAlignment = Enum.TextXAlignment.Left,
    })

    local valueLabel = create("TextLabel", {
        Parent = card,
        Text = selected .. "  â–¾",
        Font = Theme.FontRegular,
        TextSize = 13,
        TextColor3 = Theme.Accent,
        BackgroundTransparency = 1,
        Size = UDim2.new(0.5, 0, 1, 0),
        Position = UDim2.new(0.5, 0, 0, 0),
        TextXAlignment = Enum.TextXAlignment.Right,
    })

    local list = create("Frame", {
        Parent = card,
        Size = UDim2.new(1, 0, 0, #options * 28),
        Position = UDim2.new(0, 0, 1, 6),
        BackgroundColor3 = Theme.PanelAlt,
        Visible = false,
        BorderSizePixel = 0,
        ZIndex = 5,
    }, {corner(6), create("UIListLayout", {SortOrder = Enum.SortOrder.LayoutOrder})})

    for _, opt in ipairs(options) do
        local optBtn = create("TextButton", {
            Parent = list,
            Size = UDim2.new(1, 0, 0, 28),
            BackgroundTransparency = 1,
            Text = opt,
            Font = Theme.FontRegular,
            TextSize = 13,
            TextColor3 = Theme.SubText,
            ZIndex = 5,
        })
        optBtn.MouseButton1Click:Connect(function()
            selected = opt
            valueLabel.Text = selected .. "  â–¾"
            list.Visible = false
            expanded = false
            if callback then callback(selected) end
        end)
    end

    local click = create("TextButton", {
        Parent = card,
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = "",
        ZIndex = 4,
    })
    click.MouseButton1Click:Connect(function()
        expanded = not expanded
        list.Visible = expanded
    end)

    return {
        Set = function(_, v)
            selected = v
            valueLabel.Text = selected .. "  â–¾"
        end,
        Get = function() return selected end,
    }
end

