                    if optionValue ~= selected then
                        Tween(OptBtn, { BackgroundColor3 = Theme.Stroke }, 0.1)
                    end
                end)
                OptBtn.MouseLeave:Connect(function()
                    if optionValue ~= selected then
                        Tween(OptBtn, { BackgroundColor3 = Theme.ElementHover }, 0.1)
                    end
                end)
                OptBtn.MouseButton1Click:Connect(function()
                    selected = optionValue
                    SelectedLabel.Text = tostring(optionValue)
                    HighlightSelected()
                    CloseDropdown()
                    if opt.Flag then Window.Flags[opt.Flag] = selected end
                    SafeCallback(opt.Callback, optionValue)
                end)
            end
            HighlightSelected()

            Head.MouseButton1Click:Connect(function()
                open = not open
                if open then
                    -- fecha qualquer outro dropdown aberto na mesma janela
                    for _, otherApi in ipairs(Window._dropdowns) do
                        if otherApi ~= API and otherApi.Close then
                            otherApi.Close()
                        end
                    end
                    Tween(Holder, { Size = UDim2.new(1, 0, 0, 40 + #options * 30) }, 0.15)
                    Tween(Arrow, { Rotation = 180 }, 0.15)
                else
                    CloseDropdown()
                end
            end)

            function API:Set(v)
                selected = v
                SelectedLabel.Text = tostring(v)
                HighlightSelected()
                if opt.Flag then Window.Flags[opt.Flag] = selected end
            end
            function API:Get() return selected end
            API.Close = CloseDropdown

            table.insert(Window._dropdowns, API)

            Window:_Register(opt.Flag, API, selected)
            return API
        end

