            local lighting = game:GetService("Lighting")
            
            if getgenv().OriginalLightingSettings then
                lighting.Brightness = getgenv().OriginalLightingSettings.Brightness or 1
                lighting.ColorShift_Bottom = getgenv().OriginalLightingSettings.ColorShift_Bottom or Color3.new(0, 0, 0)
                lighting.ColorShift_Top = getgenv().OriginalLightingSettings.ColorShift_Top or Color3.new(0, 0, 0)
