-- Camada 2: Detecção de ambiente de dump
local function is_dump_environment()
    local sus = 0
    
    -- Verifica debug (comum em bots de dump)
    local has_debug = pcall(function() return debug.getinfo(1) end)
    if has_debug then sus = sus + 1 end
    
    -- Verifica loadstring (alguns bots bloqueiam)
    local has_loadstring = pcall(function() return loadstring("return 1") end)
    if not has_loadstring then sus = sus + 1 end
    
    -- Verifica se está rodando rápido demais (dumpers são rápidos)
    local start = os.clock()
    for i = 1, 10000 do end
    local elapsed = os.clock() - start
    if elapsed < 0.001 then sus = sus + 2 end
    
    return sus >= 2
end

