            end

            local function HighlightSelected()
                for value, btn in pairs(optionButtons) do
                    if value == selected then
                        Tween(btn, { BackgroundColor3 = Theme.Sidebar }, 0.1)
                    else
                        Tween(btn, { BackgroundColor3 = Theme.ElementHover }, 0.1)
                    end
