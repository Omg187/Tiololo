        function TabAPI:CreateSlider(opt)
            opt = opt or {}
            local min = opt.Min or 0
            local max = opt.Max or 100
            local decimals = opt.Decimals or 0
            local step = opt.Increment or (decimals > 0 and (1 / (10 ^ decimals)) or 1)
            local value = math.clamp(opt.Default or min, min, max)

            local Holder = Create("Frame", {
                Size = UDim2.new(1, 0, 0, 46),
                BackgroundColor3 = Theme.Element,
                Parent = Page,
            })
            Round(Holder, Theme.CornerSmall)

            Create("TextLabel", {
                Size = UDim2.new(1, -70, 0, 18),
                Position = UDim2.new(0, 10, 0, 6),
                BackgroundTransparency = 1,
                Font = Enum.Font.GothamBold,
                Text = opt.Title or "Slider",
                TextColor3 = Theme.Text,
                TextSize = 13,
                TextXAlignment = Enum.TextXAlignment.Left,
                Parent = Holder,
            })

            local ValueLabel = Create("TextLabel", {
                Size = UDim2.fromOffset(60, 18),
                Position = UDim2.new(1, -70, 0, 6),
                BackgroundTransparency = 1,
                Font = Enum.Font.Gotham,
                Text = tostring(value),
                TextColor3 = Theme.SubText,
                TextSize = 12,
                TextXAlignment = Enum.TextXAlignment.Right,
                Parent = Holder,
            })

            local Track = Create("Frame", {
                Size = UDim2.new(1, -20, 0, 6),
                Position = UDim2.new(0, 10, 0, 30),
                BackgroundColor3 = Theme.Sidebar,
                Parent = Holder,
            })
            Round(Track, UDim.new(1, 0))

            local Fill = Create("Frame", {
                Size = UDim2.new((value - min) / (max - min), 0, 1, 0),
                BackgroundColor3 = Theme.Accent,
                Parent = Track,
            })
            Round(Fill, UDim.new(1, 0))

            local API = {}
            local dragging = false

            local function FormatValue(v)
                if decimals > 0 then
                    return string.format("%." .. decimals .. "f", v)
                end
                return tostring(math.floor(v))
            end

            local function ApplyValue(v, fireCallback)
                value = math.clamp(Round2(v, decimals), min, max)
                local rel = (max > min) and (value - min) / (max - min) or 0
                Fill.Size = UDim2.new(rel, 0, 1, 0)
                ValueLabel.Text = FormatValue(value)
                if opt.Flag then Window.Flags[opt.Flag] = value end
                if fireCallback then SafeCallback(opt.Callback, value) end
            end

            local function UpdateFromInputX(x)
                local rel = math.clamp((x - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
                local raw = min + (max - min) * rel
                raw = math.floor(raw / step + 0.5) * step
                ApplyValue(raw, true)
            end

            Track.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = true
                    UpdateFromInputX(input.Position.X)
                end
            end)
            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = false
                end
            end)
            UserInputService.InputChanged:Connect(function(input)
                if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                    UpdateFromInputX(input.Position.X)
                end
            end)

            function API:Set(v) ApplyValue(v, false) end
            function API:Get() return value end

            Window:_Register(opt.Flag, API, value)
            return API
        end

