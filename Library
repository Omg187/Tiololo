local function ResolveTheme(themeConfig)
    local base = ThemePresets.Dark
    if type(themeConfig) == "string" and ThemePresets[themeConfig] then
        base = ThemePresets[themeConfig]
    end
    local Theme = {}
    for k, v in pairs(base) do Theme[k] = v end
    if type(themeConfig) == "table" then
        for k, v in pairs(themeConfig) do Theme[k] = v end
    end
    return Theme
end

----------------------------------------------------------------
-- UTILIDADES (corrigidas)
----------------------------------------------------------------
local function Create(class, props, children)
    local inst = Instance.new(class)
    for prop, value in pairs(props or {}) do
        inst[prop] = value
    end
    for _, child in ipairs(children or {}) do
        child.Parent = inst
    end
    return inst
end

local function Round(parent, radius)
    local corner = Instance.new("UICorner")
    corner.CornerRadius = radius or UDim.new(0, 8)
    corner.Parent = parent
    return corner
end

local function Stroke(parent, color, thickness, transparency)
    local stroke = Instance.new("UIStroke")
    stroke.Color = color or Color3.fromRGB(35, 35, 35)
    stroke.Thickness = thickness or 1
    stroke.Transparency = transparency or 0
    stroke.Parent = parent
    return stroke
end

local function Padding(parent, all)
    local pad = Instance.new("UIPadding")
    pad.PaddingLeft = UDim.new(0, all)
    pad.PaddingRight = UDim.new(0, all)
    pad.PaddingTop = UDim.new(0, all)
    pad.PaddingBottom = UDim.new(0, all)
    pad.Parent = parent
    return pad
end

local function Tween(obj, props, time, style, dir)
    if not obj or not obj.Parent then return nil end
    local tween = TweenService:Create(
        obj,
        TweenInfo.new(time or 0.2, style or Enum.EasingStyle.Quad, dir or Enum.EasingDirection.Out),
        props
    )
    tween:Play()
    return tween
end

local function SafeCallback(fn, ...)
    if not fn then return end
    local args = { ... }
    task.spawn(function()
        local ok, err = pcall(fn, table.unpack(args))
        if not ok then
            warn("[BlackUI] Erro em callback: " .. tostring(err))
        end
    end)
end

-- DRAG CORRIGIDO - Versão mais estável
local function MakeDraggable(dragHandle, target, bound)
    local dragging = false
    local dragStart, startPos
    local connections = {}

    local function update(input)
        local delta = input.Position - dragStart
        local newX = startPos.X.Offset + delta.X
        local newY = startPos.Y.Offset + delta.Y

        if bound ~= false then
            local viewport = workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize
            if viewport then
                local sizeX, sizeY = target.AbsoluteSize.X, target.AbsoluteSize.Y
                newX = math.clamp(newX, -sizeX * 0.5, viewport.X - sizeX * 0.5)
                newY = math.clamp(newY, 0, viewport.Y - 30)
            end
        end

        target.Position = UDim2.new(startPos.X.Scale, newX, startPos.Y.Scale, newY)
    end

    local function onInputBegan(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = target.Position
        end
    end

    local function onInputChanged(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            update(input)
        end
    end

    local function onInputEnded(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end

    connections[#connections + 1] = dragHandle.InputBegan:Connect(onInputBegan)
    connections[#connections + 1] = UserInputService.InputChanged:Connect(onInputChanged)
    connections[#connections + 1] = UserInputService.InputEnded:Connect(onInputEnded)

    -- Retorna uma função para limpar as conexões se necessário
    return function()
        for _, conn in ipairs(connections) do
            conn:Disconnect()
        end
        table.clear(connections)
    end
end

local function ResolveIcon(icon)
    if not icon or icon == "" then return nil end
    if typeof(icon) == "number" then
        return "rbxassetid://" .. tostring(icon)
    end
    if typeof(icon) == "string" then
        if icon:match("^rbxassetid://") or icon:match("^rbxasset://") or icon:match("^http") then
            return icon
        end
        if tonumber(icon) then
            return "rbxassetid://" .. icon
        end
    end
    return nil
end

local function Round2(value, decimals)
    local mult = 10 ^ (decimals or 0)
    return math.floor(value * mult + 0.5) / mult
end

