-- Função para copiar avatar
local function getCharacterData(character)
    if not character then return nil end
    
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not humanoid then return nil end
    
    local desc = humanoid:GetAppliedDescription()
    
    local data = {
        shirt = tonumber(desc.Shirt) or 0,
        pants = tonumber(desc.Pants) or 0,
        tshirt = tonumber(desc.GraphicTShirt) or 0,
        face = tonumber(desc.Face) or 0,
        idle = tonumber(desc.IdleAnimation) or 0,
        walk = tonumber(desc.WalkAnimation) or 0,
        run = tonumber(desc.RunAnimation) or 0,
        jump = tonumber(desc.JumpAnimation) or 0,
        fall = tonumber(desc.FallAnimation) or 0,
        climb = tonumber(desc.ClimbAnimation) or 0,
        swim = tonumber(desc.SwimAnimation) or 0
    }
    
    local accs = {}
    for _, acc in ipairs(desc:GetAccessories(true)) do
        local id = tonumber(acc.AssetId)
        if id and id > 0 then
            table.insert(accs, id)
        end
    end
    
    return {
        data = data,
        accs = accs
    }
end

AvatarTab.AddButton({
    Name = "Copy Avatar",
    Callback = function()
        pcall(function()
            if not selectedPlayer or selectedPlayer == "" then return end
            
            local targetPlayer = Services.Players:FindFirstChild(selectedPlayer)
            if not targetPlayer or not targetPlayer.Character then return end
            
            local charData = getCharacterData(targetPlayer.Character)
            if not charData then return end
            
            -- Aplicar avatar
            local remotes = Services.ReplicatedStorage:WaitForChild("Remotes")
            
            -- Carregar código de outfit
            local outfitRemote = remotes:WaitForChild("AvatarEditorOutfitCodes")
            outfitRemote:InvokeServer("Load", "BH-AE-a86898900ec74a2b8d58cb31a3d44e5e")
            task.wait(2.15)
            
            -- Mudar corpo
            local bodyRemote = remotes:WaitForChild("ChangeCharacterBody")
            bodyRemote:InvokeServer(charData.body)
            task.wait(2.15)
            
            -- Mudar cor do corpo
            local colorRemote = remotes:WaitForChild("ChangeBodyColor")
            colorRemote:FireServer(charData.skin)
            task.wait(2.15)
            
            -- Aplicar roupas
            local wearShirt = remotes:WaitForChild("WearShirt")
            local wearPants = remotes:WaitForChild("WearPants")
            local wear = remotes:WaitForChild("Wear")
            
            wearShirt:InvokeServer(charData.data.shirt)
            wearPants:InvokeServer(charData.data.pants)
            wear:InvokeServer(charData.data.tshirt)
            wear:InvokeServer(charData.data.face)
            
            -- Aplicar acessórios
            for _, id in ipairs(charData.accs) do
                wear:InvokeServer(id)
            end
            
            -- Aplicar animações
            for _, anim in ipairs({
                charData.data.idle,
                charData.data.walk,
                charData.data.run,
                charData.data.jump,
                charData.data.fall,
                charData.data.climb,
                charData.data.swim
            }) do
                wear:InvokeServer(anim)
            end
        end)
    end
})

