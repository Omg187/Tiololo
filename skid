                lighting.FogStart = getgenv().OriginalLightingSettings.FogStart or 0
                lighting.ExposureCompensation = getgenv().OriginalLightingSettings.ExposureCompensation or 0
                lighting.ShadowSoftness = getgenv().OriginalLightingSettings.ShadowSoftness or 0.5
                lighting.Ambient = getgenv().OriginalLightingSettings.Ambient or Color3.new(0, 0, 0)
            end
            
            -- Remover efeitos
            for _, inst in ipairs(getgenv().IliuminationInstances) do
                pcall(function()
                    inst:Destroy()
                end)
            end
            getgenv().IliuminationInstances = {}
            
            -- Remover efeitos adicionais
            for _, effect in ipairs({"BloomEffect", "BlurEffect", "ColorCorrectionEffect", "SunRaysEffect", "Sky"}) do
                for _, child in ipairs(lighting:GetChildren()) do
                    if child:IsA(effect) then
                        pcall(function()
                            child:Destroy()
                        end)
                    end
                end
            end
        end
    end
})

